{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@shared/*":     ["./src/shared/*"],
      "@features/*":   ["./src/features/*"],
      "@stores/*":     ["./src/stores/*"],
      "@navigation/*": ["./src/navigation/*"],
      "@theme":        ["./src/theme"],
      "@theme/*":      ["./src/theme/*"],
      "@icons":        ["./src/shared/icons"],
      "@icons/*":      ["./src/shared/icons/*"],
      "@assets":       ["./assets"],
      "@assets/*":     ["./assets/*"]
    }
  }
}
